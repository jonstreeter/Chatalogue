# Chatalogue backend environment template
# Copy this file to backend/.env and fill required values.
# Leave optional values blank if unused.

# Core access / auth
HF_TOKEN=
YOUTUBE_DATA_API_KEY=
YTDLP_COOKIES_FILE=
YTDLP_COOKIES_FROM_BROWSER=

# Transcription
TRANSCRIPTION_ENGINE=parakeet
TRANSCRIPTION_MODEL=small
TRANSCRIPTION_COMPUTE_TYPE=float16
TRANSCRIPTION_BEAM_SIZE=5
TRANSCRIPTION_VAD_FILTER=true
TRANSCRIPTION_BATCHED=true
WHISPER_BACKEND=faster_whisper
MULTILINGUAL_ROUTING_ENABLED=true
MULTILINGUAL_WHISPER_MODEL=large-v3
LANGUAGE_DETECTION_SAMPLE_SECONDS=45
LANGUAGE_DETECTION_CONFIDENCE_THRESHOLD=0.65

# Parakeet
PARAKEET_MODEL=nvidia/parakeet-tdt-0.6b-v2
PARAKEET_BATCH_SIZE=16
PARAKEET_REQUIRE_WORD_TIMESTAMPS=true
PARAKEET_BATCH_AUTO=true
PARAKEET_UNLOAD_AFTER_TRANSCRIBE=false
PARAKEET_ALLOW_WHISPER_FALLBACK=true
PARAKEET_OOM_CHUNK_RETRY=true
PARAKEET_OOM_CHUNK_SECONDS=900
PARAKEET_OOM_MIN_CHUNK_SECONDS=120
PARAKEET_OOM_CHUNK_OVERLAP_SECONDS=8
PARAKEET_QUEUE_THROUGHPUT_GUARD=true
PARAKEET_QUEUE_BACKLOG_WHISPER_THRESHOLD=1
PARAKEET_QUEUE_LONG_AUDIO_WHISPER_THRESHOLD_SECONDS=1200

# Pipeline / queue
PIPELINE_EXECUTION_MODE=sequential
VERBOSE_LOGGING=false

# Diarization / speaker matching
DIARIZATION_SENSITIVITY=balanced
SPEAKER_MATCH_THRESHOLD=0.35
SPEAKER_PROFILE_SAMPLE_COUNT=12
SPEAKER_PROFILE_MIN_SAMPLE_SECONDS=1.2
SPEAKER_PROFILE_FALLBACK_MIN_SECONDS=0.8
SPEAKER_PROFILE_PERSIST_RAW_SAMPLES=false

# LLM providers
LLM_ENABLED=false
LLM_PROVIDER=
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_MODEL_TIER=
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
ANTHROPIC_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=
GEMINI_API_KEY=
GROQ_BASE_URL=
GROQ_MODEL=
GROQ_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_MODEL=
OPENROUTER_API_KEY=
XAI_BASE_URL=
XAI_MODEL=
XAI_API_KEY=
NVIDIA_NIM_BASE_URL=
NVIDIA_NIM_MODEL=
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_THINKING_MODE=

# Funny moments
FUNNY_MOMENTS_MAX_SAVED=12
FUNNY_MOMENTS_EXPLAIN_BATCH_LIMIT=8
NVIDIA_NIM_MIN_REQUEST_INTERVAL_SECONDS=0

# YouTube publishing
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REDIRECT_URI=
YOUTUBE_PUBLISH_PUSH_ENABLED=false

# Reconstruction / dubbing-adjacent runtime tuning
RECONSTRUCTION_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-Base
RECONSTRUCTION_XVECTOR_ONLY=true
RECONSTRUCTION_DO_SAMPLE=false
RECONSTRUCTION_BATCH_SIZE=4
RECONSTRUCTION_BATCH_TOKEN_BUDGET=1200
RECONSTRUCTION_BATCH_DURATION_BUDGET_SECONDS=45
RECONSTRUCTION_FALLBACK_SEGMENT_SECONDS=14
RECONSTRUCTION_FALLBACK_SEGMENT_WORDS=72
RECONSTRUCTION_FALLBACK_SEGMENT_CHARS=440
RECONSTRUCTION_ISOLATE_SEGMENT_SECONDS=7.5
RECONSTRUCTION_ISOLATE_SEGMENT_WORDS=34
RECONSTRUCTION_ISOLATE_SEGMENT_CHARS=220

# Database
DB_PROVIDER=postgres
